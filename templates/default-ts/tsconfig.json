{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "types": [
      "@wunk/lb-script-api-types/ambient"
      // Toggle: to type `Java.type("net.ccbluex...")` straight from the string
      // (LiquidBounce classes), uncomment the next line. Otherwise use explicit
      // imports (see src/examples/explicit-imports.ts). Use registry-full instead
      // to also cover net.minecraft.* classes.
      // , "@wunk/lb-script-api-types/registry-lb"
    ],
    "noEmit": true
  },
  "include": ["src/**/*", "types/**/*"],
  "exclude": ["dist", "node_modules", "vendor"]
}
