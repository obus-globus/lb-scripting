{
  "name": "lb-inject-template",
  "private": true,
  "version": "0.1.0",
  "description": "TypeScript starter for LiquidBounce (nextgen) scripts that use lb-inject runtime bytecode injection, fully typed against @wunk/lb-script-api-types.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:bundle": "node scripts/build.mjs --bundle",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@wunk/lb-script-api-types": "^0.38.4",
    "esbuild": "^0.23",
    "typescript": "^5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
