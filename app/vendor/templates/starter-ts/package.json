{
  "name": "lb-script-template",
  "private": true,
  "version": "0.1.0",
  "description": "Starter project for writing a LiquidBounce (nextgen) script with full TypeScript types.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:bundle": "node scripts/build.mjs --bundle",
    "watch": "node scripts/build.mjs --watch",
    "dev": "node scripts/build.mjs --watch --dev",
    "typecheck": "tsc --noEmit",
    "setup:references": "node scripts/setup-references.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@wunk/lb-script-api-types": "^0.38.4",
    "esbuild": "^0.23",
    "typescript": "^5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
