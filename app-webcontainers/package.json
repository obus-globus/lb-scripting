{
  "name": "lb-ide-app-webcontainers",
  "version": "0.1.0",
  "private": true,
  "description": "WebContainers edition of the browser LB script IDE: Monaco type-checking + REAL in-tab npm/esbuild build via StackBlitz WebContainers, per-session IndexedDB persistence.",
  "type": "module",
  "scripts": {
    "gen-typings": "node scripts/gen-typings.mjs",
    "bundle-api": "node scripts/bundle-api.mjs",
    "postinstall": "node scripts/gen-typings.mjs && node scripts/bundle-api.mjs",
    "build-dist": "node scripts/build-dist.mjs",
    "serve": "node serve.mjs",
    "verify": "node verify.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@webcontainer/api": "^1.5.3",
    "@wunk/lb-script-api-types": "^0.38.4",
    "monaco-editor": "^0.52.2",
    "typescript": "5.4"
  },
  "devDependencies": {
    "esbuild": "^0.23.1",
    "puppeteer-core": "^23.11.1"
  }
}
